# Hyperliquid Configuration
# Copy this file to the project root as .env:
#   cp config/example.env .env
# Then fill in your values

# Required: Your wallet private key (with 0x prefix)
# WARNING: Keep this secret! Never commit .env to git
HYPERLIQUID_PRIVATE_KEY=0x...

# Optional: Network (mainnet or testnet, defaults to mainnet)
# Use testnet for testing: HYPERLIQUID_NETWORK=testnet
HYPERLIQUID_NETWORK=mainnet

# Optional: Builder fee address (defaults to open-broker address)
# BUILDER_ADDRESS=0x...

# Optional: Builder fee in tenths of basis points (10 = 1 bps, defaults to 10)
# BUILDER_FEE=10

# Optional: Default slippage in basis points (defaults to 50 = 0.5%)
# SLIPPAGE_BPS=50

# Optional: Enable verbose logging for debugging
# VERBOSE=1
